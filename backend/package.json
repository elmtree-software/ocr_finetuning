{
  "name": "ocrfinetuning-backend",
  "version": "0.1.0",
  "description": "Node.js backend for OCR finetuning (WebSocket + model server)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "models:ocr": "node ../scripts/install_ocr_models.mjs",
    "models:ocr:opencv": "node ../scripts/install_ocr_models.mjs opencv",
    "models:ocr:paddle": "node ../scripts/install_ocr_models.mjs paddle",
    "tesseract:patch": "node ../scripts/patch_tesseract_node_getcore.mjs",
    "postinstall": "node ../scripts/patch_tesseract_node_getcore.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
