{
    "baseConfig": {
        "engine": "tesseract",
        "rectification": {
            "enabled": true,
            "minContourConfidence": 0.5,
            "minDocumentArea": 0.3,
            "cannyLow": 125,
            "cannyHigh": 100,
            "blurSize": 3,
            "useAdaptiveThreshold": true
        },
        "preprocessing": {
            "enabled": true,
            "grayscale": true,
            "contrastBoost": 1.667,
            "dpiScaling": {
                "enabled": true,
                "minCapitalHeightPx": 35,
                "maxScale": 2
            },
            "inversionDetection": {
                "enabled": true,
                "brightnessThreshold": 128
            },
            "clahe": {
                "enabled": true,
                "clipLimit": 1.0,
                "tileSize": 16
            },
            "bilateralFilter": {
                "enabled": false,
                "diameter": 5,
                "sigmaColor": 75,
                "sigmaSpace": 75
            },
            "threshold": {
                "enabled": false,
                "type": "otsu",
                "value": 128
            }
        },
        "layout": {
            "enabled": true,
            "detectionThreshold": 0.1,
            "regionPadding": 15,
            "internalPadding": 5,
            "nms": {
                "iouThreshold": 0.6,
                "containmentThreshold": 0.3
            },
            "xyCut": {
                "enabled": true,
                "minGapThreshold": 30,
                "spanningThreshold": 0.7,
                "maxDepth": 16
            }
        },
        "rotation": {
            "enabled": true,
            "fastMode": true,
            "skipThreshold": 55,
            "minImprovement": 3,
            "angleStep": 90
        },
        "fallback": {
            "enabled": true,
            "gridSize": 120,
            "minAreaRatio": 0.05,
            "minConfidence": 0.4
        },
        "table": {
            "enabled": true,
            "outputFormat": "markdown",
            "rowClusterTolerance": 15,
            "colClusterTolerance": 30
        },
        "output": {
            "minTextLength": 1,
            "minLineConfidence": 0.5,
            "minWordConfidence": 0.325
        }
    },
    "iterateParams": {
        "preprocessing.bilateralFilter.enabled": {
            "enabled": true
        },
        "preprocessing.bilateralFilter.diameter": {
            "enabled": true,
            "min": 3,
            "max": 11,
            "steps": 3
        },
        "preprocessing.bilateralFilter.sigmaColor": {
            "enabled": true,
            "min": 25,
            "max": 150,
            "steps": 4
        },
        "preprocessing.bilateralFilter.sigmaSpace": {
            "enabled": true,
            "min": 25,
            "max": 150,
            "steps": 4
        },
        "preprocessing.threshold.enabled": {
            "enabled": true
        },
        "preprocessing.threshold.type": {
            "enabled": true,
            "selectedValues": ["otsu", "adaptive", "binary"]
        }
    },
    "optimizer": {
        "iterations": 80,
        "initialSamples": 20,
        "candidateSamples": 400
    },
    "scoringMode": "fulltext",
    "imagesDir": "./ocr_trainingdata/sel_gt"
}
