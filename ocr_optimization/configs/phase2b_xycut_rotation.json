{
    "baseConfig": {
        "engine": "tesseract",
        "rectification": {
            "enabled": true,
            "minContourConfidence": 0.5,
            "minDocumentArea": 0.3,
            "cannyLow": 125,
            "cannyHigh": 100,
            "blurSize": 3,
            "useAdaptiveThreshold": true
        },
        "preprocessing": {
            "enabled": true,
            "grayscale": true,
            "contrastBoost": 2.0,
            "dpiScaling": {
                "enabled": true,
                "minCapitalHeightPx": 20,
                "maxScale": 4
            },
            "inversionDetection": {
                "enabled": true,
                "brightnessThreshold": 128
            },
            "clahe": {
                "enabled": true,
                "clipLimit": 2.0,
                "tileSize": 8
            },
            "bilateralFilter": {
                "enabled": false,
                "diameter": 5,
                "sigmaColor": 75,
                "sigmaSpace": 75
            },
            "threshold": {
                "enabled": false,
                "type": "otsu",
                "value": 128
            }
        },
        "layout": {
            "enabled": true,
            "detectionThreshold": 0.1,
            "regionPadding": 15,
            "internalPadding": 5,
            "nms": {
                "iouThreshold": 0.6,
                "containmentThreshold": 0.3
            },
            "xyCut": {
                "enabled": true,
                "minGapThreshold": 25,
                "spanningThreshold": 0.7,
                "maxDepth": 14
            }
        },
        "rotation": {
            "enabled": true,
            "fastMode": false,
            "skipThreshold": 70,
            "minImprovement": 5,
            "angleStep": 90
        },
        "fallback": {
            "enabled": true,
            "gridSize": 80,
            "minAreaRatio": 0.14,
            "minConfidence": 0.45
        },
        "table": {
            "enabled": true,
            "outputFormat": "markdown",
            "rowClusterTolerance": 15,
            "colClusterTolerance": 30
        },
        "output": {
            "minTextLength": 2,
            "minLineConfidence": 0.4,
            "minWordConfidence": 0.5
        }
    },
    "iterateParams": {
        "layout.xyCut.minGapThreshold": {
            "enabled": true,
            "min": 10,
            "max": 50,
            "steps": 3
        },
        "layout.xyCut.spanningThreshold": {
            "enabled": true,
            "min": 0.5,
            "max": 0.9,
            "steps": 3
        },
        "layout.xyCut.maxDepth": {
            "enabled": true,
            "min": 6,
            "max": 16,
            "steps": 3
        },
        "rotation.enabled": {
            "enabled": true
        },
        "rotation.fastMode": {
            "enabled": true
        },
        "rotation.skipThreshold": {
            "enabled": true,
            "min": 30,
            "max": 80,
            "steps": 3
        },
        "rotation.minImprovement": {
            "enabled": true,
            "min": 3,
            "max": 15,
            "steps": 3
        }
    },
    "optimizer": {
        "iterations": 80,
        "initialSamples": 20,
        "candidateSamples": 400
    },
    "scoringMode": "fulltext",
    "imagesDir": "./ocr_trainingdata/sel_gt"
}