{
  "name": "ocrfinetuning-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:ort": "node ../scripts/sync-onnxruntime-web-assets.mjs",
    "dev": "npm run prepare:ort && vite --open /ocr_finetuning.html",
    "build": "npm run prepare:ort && vite build",
    "preview": "vite preview --open /ocr_finetuning.html",
    "server": "cd ../backend && npm run dev"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-web": "^1.23.2",
    "tesseract.js": "^7.0.0",
    "vue": "^3.4.27"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.0"
  }
}
